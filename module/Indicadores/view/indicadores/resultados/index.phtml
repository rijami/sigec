                        sLoadingRecords: "CARGANDO...",
                        sProcessing: "EN PROCESO...",
                        sSearch: "Buscar:",
                        sEmptyTable: "NO HAY INFORMACION DISPONIBLE PARA LA TABLA",
                        oPaginate: {
                            sFirst: "<i class=\'fa fa-fast-backward\' aria-hidden=\'true\' title=\'Inicio\'></i>",
                            sPrevious: "<i class=\'fa fa-step-backward\' aria-hidden=\'true\' title=\'Anterior\'></i>",
                            sNext: "<i class=\'fa fa-step-forward\' aria-hidden=\'true\' title=\'Siguiente\'></i>",
                            sLast: "<i class=\'fa fa-fast-forward\' aria-hidden=\'true\' title=\'Fin\'></i>",
                        }
                    },
                    aaSorting: [[0, "desc"]]
                });

                // Lógica corregida para el cierre del modal
                $("#modalFormulario").on("hide.bs.modal", function (e) {
                    // Si el cierre viene del AJAX (guardado exitoso), dejar pasar
                    if (window.cierreProgramado === true) {
                        return true;
                    }

                    // Si es manual, evitar el cierre y preguntar
                    e.preventDefault();
                    
                    Swal.fire({
                        title: "&iquest;DESEA CERRAR EL FORMULARIO?",
                        text: "Se perderán los datos no guardados.",
                        icon: "question",
                        showCancelButton: true,
                        confirmButtonText: "Si, cerrar",
                        cancelButtonText: "No, continuar",
                        allowOutsideClick: false
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // Autorizar cierre y cerrar manualmente
                            window.cierreProgramado = true;
                            $("#modalFormulario").modal("hide");
                        }
                    });
                });

                // Resetear la variable cuando el modal esté completamente cerrado
                $("#modalFormulario").on("hidden.bs.modal", function () {
                    window.cierreProgramado = false;
                });

                ' . $mostrarMensajes . '
            });', 'text/javascript', array('noescape' => true))
