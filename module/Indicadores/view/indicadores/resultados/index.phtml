            <?php
            // Supongamos que $datos es el array que ya usas para llenar la tabla
            $labels = [];
            $valores = [];
            $datos = $this->resultados;
            foreach ($datos as $fila) {
                // Guardamos los meses para el eje X
                $labels[] = $fila['mes'];
                // Limpiamos el % para que sea numérico (ej: "83.3%" -> 83.3)
                $valores[] = floatval(str_replace('%', '', $fila['resultado']));
            }

            // Invertimos los arrays si quieres que el orden sea cronológico (de más viejo a más nuevo)
            $labels = array_reverse($labels);
            $valores = array_reverse($valores);
            ?>

            <script>
                $(document).ready(function () {
                    // Obtenemos el contexto del canvas
                    const ctx = document.getElementById('graficaMismaVista').getContext('2d');

                    // Si ya existe una instancia (por recargas AJAX), la destruimos
                    if (window.chartPrincipal) {
                        window.chartPrincipal.destroy();
                    }

                    window.chartPrincipal = new Chart(ctx, {
                        type: 'line', // 'line' queda muy bien para ver la evolución de meses
                        data: {
                            labels: <?php echo json_encode($labels); ?>,
                            datasets: [{
                                label: 'Porcentaje de Resultado',
                                data: <?php echo json_encode($valores); ?>,
                                borderColor: '#84BB4E',
                                backgroundColor: 'rgba(104, 184, 68, 0.2)',
                                borderWidth: 3,
                                tension: 0.3, // Curva un poco la línea para que sea elegante
                                fill: true,
                                pointBackgroundColor: '#f1f108',
                                pointRadius: 5
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    max: 150, // Como son porcentajes, el límite es 100
                                    ticks: {
                                        callback: function (value) { return value + "%"; }
                                    }
                                }
                            },
                            plugins: {
                                legend: { display: false } // Ocultamos la leyenda para ahorrar espacio
                            }
                        }
                    });
                });
            </script>
