                    $fechaActual = new DateTime();
                    $fechaLimite = new DateTime($this->infoIndicador['fechalimactivacion']);
                    $diasRestantes = "";
                    $dias = "";
                    //echo "limite" . print_r($this->infoIndicador['fechalimactivacion']);
                    // echo "Actual" . $fechaActual;
                    if ($this->infoIndicador['fechalimactivacion'] < $fechaHoy) {
                        $diasRestantes = "";
                        $dias = "";
                        $fechaLimite = "Vencido";
                        $class = "class='form-control text-danger font-weight-bold'";
                    } else {
                        $diasRestantes = $fechaActual->diff($fechaLimite)->days;
                        if ($diasRestantes === 0) {
                            $dias = "";
                            $fechaLimite = "Vence Hoy";
                            $diasRestantes = "";
                            $class = "class='form-control text-warning font-weight-bold'";
                        } elseif ($diasRestantes <= 3) {
                            $fechaLimite = "Vence en";
                            $dias = "Dias";
                            $class = "class='form-control text-info font-weight-bold'";
                        } elseif ($diasRestantes <= 7) {
                            $dias = "Dias";
                            $class = "class='form-control text-primary font-weight-bold'";
                            $fechaLimite = 'Vence en';
                        } else {
                            $dias = "Dias";
                            $class = "class='form-control text-success font-weight-bold'";
                            $fechaLimite = 'Con tiempo';
                        }
                    }
